# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guildforge

# ─── Discord Application ─────────────────────────────────────────────────────
# Create your app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ─── AI ──────────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be a long random string (use: openssl rand -base64 32)
SESSION_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Optional ────────────────────────────────────────────────────────────────
# If deploying MCP server separately, set its URL here
# MCP_DISCORD_URL=http://localhost:3002/sse
