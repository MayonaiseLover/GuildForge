# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guildforge

# ─── Discord Application ─────────────────────────────────────────────────────
# Create your app at https://discord.com/developers/applications
#
# ⚠️  IMPORTANT: Add this redirect URI in your Discord app's OAuth2 settings:
#     http://localhost:3001/auth/discord/callback
#     (For production: https://api.yourdomain.com/auth/discord/callback)
#
# Also enable "Server Members Intent" under Bot → Privileged Gateway Intents
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# ─── LLM Providers ──────────────────────────────────────────────────────────
# At least one API key is required. Set LLM_PROVIDER to your default.
LLM_PROVIDER=anthropic

# Anthropic (default) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Groq (ultra-fast) — https://console.groq.com/keys
# GROQ_API_KEY=

# xAI Grok — https://console.x.ai
# GROK_API_KEY=

# DeepSeek — https://platform.deepseek.com
# DEEPSEEK_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────────────
# ⚠️  REQUIRED — the API will NOT start without this in production.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=

# ─── URLs ────────────────────────────────────────────────────────────────────
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
API_PORT=3001

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Stripe Billing (optional) ───────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_MONTHLY_PRICE_ID=
# STRIPE_PRO_YEARLY_PRICE_ID=
# STRIPE_STUDIO_MONTHLY_PRICE_ID=
# STRIPE_STUDIO_YEARLY_PRICE_ID=

# ─── Optional ────────────────────────────────────────────────────────────────
# If deploying MCP server separately, set its URL here
# MCP_DISCORD_URL=http://localhost:3002/sse

# ─── Docker ──────────────────────────────────────────────────────────────────
# When using docker-compose, DATABASE_URL is overridden to use the postgres
# service hostname. You only need to fill in Discord + LLM keys above.
