generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  discordId         String   @unique
  username          String
  avatar            String?
  email             String?
  plan              String   @default("free")     // free | pro | studio
  createdAt         DateTime @default(now())
  sessions          Session[]
  conversations     Conversation[]
  managedGuilds     ManagedGuild[]
  templates         ServerTemplate[]
  templateStars     Templatestar[]
  buildEvents       BuildEvent[]
  subscription      Subscription?
  ownedTeams        Team[]       @relation("TeamOwner")
  teamMemberships   TeamMember[]
  alertRules        AlertRule[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  provider     String
  providerUserId String
  userId       String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  @@id([provider, providerUserId])
}

model ManagedGuild {
  id              String   @id @default(cuid())
  discordGuildId  String   @unique
  ownerUserId     String
  guildName       String
  iconUrl         String?
  botSetupStatus  Json?
  lastAuditAt     DateTime?
  createdAt       DateTime @default(now())
  conversations   Conversation[]
  buildPlans      BuildPlan[]
  snapshots       SnapshotRecord[]
  user            User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String     @id @default(cuid())
  userId    String
  guildId   String
  createdAt DateTime   @default(now())
  messages  Message[]
  buildPlans BuildPlan[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild     ManagedGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // user | assistant | tool
  content         String   @db.Text
  toolCalls       Json?
  createdAt       DateTime @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model BuildPlan {
  id              String   @id @default(cuid())
  conversationId  String
  guildId         String
  planJson        Json
  status          String   // DRAFT | APPROVED | EXECUTING | COMPLETED | FAILED | ROLLED_BACK
  createdAt       DateTime @default(now())
  executedAt      DateTime?
  operations      Operation[]
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  guild           ManagedGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model Operation {
  id          String   @id @default(cuid())
  buildPlanId String
  ord         Int
  tool        String
  args        Json
  result      Json?
  status      String   // PENDING | OK | FAILED | SKIPPED
  startedAt   DateTime?
  finishedAt  DateTime?
  buildPlan   BuildPlan @relation(fields: [buildPlanId], references: [id], onDelete: Cascade)
}

model SnapshotRecord {
  id              String   @id @default(cuid())
  guildId         String
  label           String?
  structureJson   Json
  createdAt       DateTime @default(now())
  guild           ManagedGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

// ── Phase 8: Community Templates ──────────────────────────────────────────────

model ServerTemplate {
  id          String   @id @default(cuid())
  name        String
  description String   @db.Text
  category    String   // gaming | dev | community | study | nft | agency | other
  tags        String[] @default([])
  planJson    Json
  authorId    String
  isPublic    Boolean  @default(true)
  starCount   Int      @default(0)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  stars       Templatestar[]

  @@index([category])
  @@index([starCount])
  @@index([isPublic])
}

model Templatestar {
  userId     String
  templateId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   ServerTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@id([userId, templateId])
}

// ── Phase 9: Analytics ─────────────────────────────────────────────────────────

model BuildEvent {
  id         String   @id @default(cuid())
  userId     String
  guildId    String?
  eventType  String   // DEPLOY | ROLLBACK | SNAPSHOT | AUDIT | PLAN_GENERATED | CHAT_MESSAGE
  metadata   Json?    // channels_created, roles_created, operations_count, etc.
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([createdAt])
}

// ── Phase 10: Stripe Billing ──────────────────────────────────────────────────

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  stripeCustomerId      String    @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  plan                  String    @default("free")   // free | pro | studio
  status                String    @default("active") // active | canceled | past_due | trialing | paused
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)
  trialEnd              DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
}

model PaymentEvent {
  id                    String   @id @default(cuid())
  stripeEventId         String   @unique
  eventType             String   // checkout.session.completed | invoice.paid | customer.subscription.updated | etc.
  userId                String?
  amount                Int?     // cents
  currency              String?  @default("usd")
  metadata              Json?
  createdAt             DateTime @default(now())

  @@index([userId])
  @@index([eventType])
}

// ── Phase 11: Team Workspaces ─────────────────────────────────────────────────

model Team {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  avatarUrl    String?
  ownerId      String
  plan         String       @default("free")
  maxMembers   Int          @default(5)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  owner        User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      TeamMember[]
  invites      TeamInvite[]
  guilds       TeamGuild[]

  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member") // owner | admin | member | viewer
  joinedAt  DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

model TeamInvite {
  id        String   @id @default(cuid())
  teamId    String
  email     String
  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime
  accepted  Boolean  @default(false)
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model TeamGuild {
  id       String @id @default(cuid())
  teamId   String
  guildId  String
  addedAt  DateTime @default(now())
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, guildId])
}

// ── Phase 12: Server Health Monitoring & Alerts ───────────────────────────────

model HealthCheck {
  id              String   @id @default(cuid())
  guildId         String
  status          String   // HEALTHY | DEGRADED | CRITICAL | UNKNOWN
  memberCount     Int?
  channelCount    Int?
  roleCount       Int?
  boostLevel      Int?
  onlineCount     Int?
  messageVolume   Int?     // messages in last 24h (estimated)
  issues          Json?    // array of { severity, code, message }
  checkedAt       DateTime @default(now())

  @@index([guildId, checkedAt])
  @@index([status])
}

model AlertRule {
  id            String   @id @default(cuid())
  userId        String
  guildId       String?
  name          String
  condition     String   // member_drop | channel_inactive | role_unused | boost_lost | permission_drift
  threshold     Json     // { value: number, unit: string, period: string }
  channels      String[] @default([]) // notification channels: "email" | "discord" | "webhook"
  webhookUrl    String?
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts        Alert[]

  @@index([userId, isActive])
  @@index([guildId])
}

model Alert {
  id          String    @id @default(cuid())
  ruleId      String
  guildId     String
  severity    String    // info | warning | critical
  title       String
  message     String    @db.Text
  metadata    Json?
  acknowledged Boolean  @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt   DateTime  @default(now())
  rule        AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([guildId, acknowledged])
  @@index([severity])
  @@index([createdAt])
}

