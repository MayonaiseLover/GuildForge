# Allow build scripts for approved packages (pnpm 11+ security feature)
# These packages need postinstall scripts to function:
#   @prisma/client, @prisma/engines — Prisma engine binary download
#   esbuild — Platform-specific binary download
#   prisma — Schema engine download
#   sharp — libvips native addon
#   msw — Service worker setup
#   unrs-resolver — Native binding compilation
onlyBuiltDependencies[]= @prisma/client
onlyBuiltDependencies[]= @prisma/engines
onlyBuiltDependencies[]= esbuild
onlyBuiltDependencies[]= msw
onlyBuiltDependencies[]= prisma
onlyBuiltDependencies[]= sharp
onlyBuiltDependencies[]= unrs-resolver
