{
  "name": "@guildforge/mcp-discord",
  "version": "1.0.0",
  "description": "A standalone Model Context Protocol (MCP) server for managing Discord servers.",
  "author": "GuildForge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/guildforge/guildforge.git",
    "directory": "apps/mcp-discord"
  },
  "type": "module",
  "bin": {
    "guildforge-mcp-discord": "./dist/server.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src/knowledge",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean && cp -r src/knowledge dist/knowledge",
    "dev": "tsup src/server.ts --format esm --watch --onSuccess 'node dist/server.js'",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no linter configured'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@napi-rs/canvas": "^1.0.0",
    "discord.js": "^14.16.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
